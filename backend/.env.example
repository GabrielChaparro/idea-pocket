# Spring Boot
PORT=8080

# PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/ideapocket
DATABASE_USER=ideapocket
DATABASE_PASSWORD=ideapocket

# JWT
# Use a strong secret in real environments. Keep it out of Git.
JWT_SECRET=replace-with-a-strong-secret-of-at-least-32-characters
JWT_EXPIRATION_MINUTES=60

# CORS
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

